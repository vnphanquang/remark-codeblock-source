{
	"name": "remark-codeblock-source",
	"version": "1.0.0",
	"description": "load codeblock content from external source (e.g. filesytem, GitHub, etc.)",
	"license": "MIT",
	"author": {
		"email": "oss@vnphanquang.com",
		"name": "quang",
		"url": "https://github.com/vnphanquang"
	},
	"homepage": "https://github.com/vnphanquang/remark-codeblock-source",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vnphanquang/remark-codeblock-source.git"
	},
	"bugs": {
		"url": "https://github.com/vnphanquang/remark-codeblock-source/issues"
	},
	"keywords": [
		"remark",
		"unified",
		"codeblock",
		"import",
		"fetch",
		"remote",
		"fs",
		"source"
	],
	"type": "module",
	"main": "src/index.js",
	"types": "types/index.d.ts",
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"import": "./src/index.js"
		},
		"./resolvers": {
			"types": "./types/index.d.ts",
			"import": "./src/resolvers/index.js"
		}
	},
	"files": [
		"src",
		"types",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"lint:es": "eslint .",
		"lint": "run-p lint:*",
		"format": "prettier . --check",
		"dts": "dts-buddy --write && publint",
		"test": "vitest --coverage --browser.headless",
		"prepublishOnly": "pnpm dts",
		"ci:test": "vitest run --coverage",
		"ci:version": "changeset version",
		"ci:publish": "changeset tag && pnpm publish -r --no-git-checks --access public"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@types/mdast": "^4.0.4",
		"@types/node": "^24.13.2",
		"@vitest/coverage-v8": "^4.1.9",
		"@vitest/ui": "^4.1.9",
		"@vnphanquang/eslint-config": "^4.2.1",
		"dedent": "^1.7.2",
		"dts-buddy": "^0.8.2",
		"eslint": "^10.6.0",
		"eslint-plugin-jsdoc": "^63.0.10",
		"memfs": "^4.57.8",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.9.1",
		"prettier-plugin-embed": "^0.5.1",
		"publint": "^0.3.21",
		"rehype-stringify": "^10.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"typescript": "^6.0.3",
		"unified": "^11.0.5",
		"vfile": "^6.0.3",
		"vite": "^8.1.2",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"unist-builder": "^4.0.0",
		"unist-util-visit": "^5.1.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "24.16.0",
			"onFail": "download"
		},
		"packageManager": {
			"name": "pnpm",
			"version": "^11.9.0",
			"onFail": "download"
		}
	}
}
